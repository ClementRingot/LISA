# ─── SAP Connection (local dev — not used when SAP_BTP_DESTINATION is set) ───
SAP_URL=https://your-abap-system.example.com
SAP_USERNAME=ABAP_USER
SAP_PASSWORD=secret
SAP_CLIENT=100

# ─── HTTP Service path ────────────────────────────────────────────────────────
# ICF path of the zi18n_service handler registered in SICF.
# The MCP will call  <SAP_URL><SAP_I18N_SERVICE_PATH>?<params>
# Adjust to match your system's ICF node, e.g.:
#   /sap/bc/http/sap/zi18n_service   (classic HTTP handler)
SAP_I18N_SERVICE_PATH=/sap/bc/http/sap/zi18n_service

# ─── BTP Destination (used in BTP deployment instead of SAP_URL/user/pass) ───
# SAP_BTP_DESTINATION=SAP_SYSTEM_TECH_DEV          # BasicAuth — fallback / startup
# SAP_BTP_PP_DESTINATION=SAP_SYSTEM_SSO_DEV        # PrincipalPropagation — per-user calls
#   On-premise (Cloud Connector): destination Auth=PrincipalPropagation, ProxyType=OnPremise.
#   S/4HANA Public Cloud: point this at a destination Auth=SAMLAssertion, ProxyType=Internet
#   (no extra var — the SAML assertion is detected and forwarded automatically).

# ─── MCP transport ───────────────────────────────────────────────────────────
MCP_TRANSPORT=http-streamable   # http-streamable | stdio
PORT=8080

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info     # debug | info | warn | error
LOG_FORMAT=text    # text | json

# ─── Authentication ───────────────────────────────────────────────────────────
# Leave ALL auth vars unset to disable authentication (useful for local testing).
# Auth is active only when at least one of the following is configured.
#
# API keys   key:profile,key2:profile2    profiles: viewer | developer | admin
# SAP_API_KEYS=mykey123:developer

# OIDC/Entra ID
# OIDC_AUDIENCE is REQUIRED when OIDC_ISSUER is set (the server refuses to start
# otherwise — prevents token confusion on shared issuers). Entra: a v2.0 token
# carries the raw client-id GUID in `aud`; a v1.0 token carries api://<app-id>.
# OIDC_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# OIDC_AUDIENCE=api://<app-id>
# Explicit, discouraged opt-out: start with an issuer but no audience check.
# OIDC_ALLOW_ANY_AUDIENCE=true

# XSUAA (injected automatically by BTP; set manually for local XSUAA testing)
# VCAP_SERVICES={"xsuaa":[{"credentials":{...}}]}
