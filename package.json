{
  "name": "lisa",
  "version": "0.8.1",
  "description": "LISA — SAP object translation. Workspaces: @lisa/core (shared wire contract), the standalone MCP server (deployable on BTP), and the ARC-1 extension.",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/arc1-extension",
    "packages/server"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "start": "node packages/server/dist/index.js",
    "dev": "npm run dev --workspace packages/server",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "biome format --write packages/*/src/",
    "clean": "npm run clean --workspaces --if-present",
    "check:version": "node scripts/check-version-sync.mjs",
    "release": "./scripts/release.sh",
    "btp:build": "mbt build",
    "btp:deploy": "cf deploy mta_archives/lisa_$npm_package_version.mtar",
    "btp:deploy-dev": "cf deploy mta_archives/lisa_$npm_package_version.mtar -e mta-overrides-dev.mtaext",
    "btp:deploy-sbx": "cf deploy mta_archives/lisa_$npm_package_version.mtar -e mta-overrides-sbx.mtaext",
    "btp:deploy-prod": "cf deploy mta_archives/lisa_$npm_package_version.mtar -e mta-overrides-prod.mtaext",
    "btp:build-deploy": "npm run btp:build && npm run btp:deploy",
    "btp:build-deploy-dev": "npm run btp:build && npm run btp:deploy-dev",
    "btp:build-deploy-sbx": "npm run btp:build && npm run btp:deploy-sbx",
    "btp:build-deploy-prod": "npm run btp:build && npm run btp:deploy-prod"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  }
}
