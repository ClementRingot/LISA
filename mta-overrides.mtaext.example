# ──────────────────────────────────────────────────────────────────────
# MTA Extension Descriptor — Environment-Specific Overrides (TEMPLATE)
#
# This is a tracked template. Copy it to a real, per-landscape file (all
# `mta-overrides*.mtaext` are gitignored) and fill in your landscape values —
# one file per landscape, e.g. `-dev` / `-sbx`:
#
#   cp mta-overrides.mtaext.example mta-overrides-dev.mtaext
#   # edit mta-overrides-dev.mtaext
#
# Then build + deploy with the extension applied:
#
#   npm run btp:build-deploy-dev        # or btp:build-deploy-sbx for sandbox
#   # or, manually:
#   mbt build
#   cf deploy mta_archives/lisa_<version>.mtar -e mta-overrides-dev.mtaext
#
# Any property left commented uses the `mta.yaml` value unchanged.
# ──────────────────────────────────────────────────────────────────────

_schema-version: "3.1"
ID: lisa-overrides
extends: lisa

modules:
  - name: lisa-mcp
    # ── Route host — pick your public URL (recommended) ──────────────
    # Base mta.yaml sets NO host, so the deploy service assigns a globally
    # unique but long auto-host (e.g.
    # myorg-1a2b3c4d-dev-myspace-lisa-mcp.cfapps.<region>...). To deploy under a
    # short URL you control — the one your MCP clients connect to — pin `host:`
    # here. This LISA landscape keeps the `lisa-<space>` convention, so in the
    # `dev` space the route resolves to https://lisa-dev.cfapps.<region>.../mcp
    parameters:
      host: lisa-${space}          # dev space -> lisa-dev
    # The host must be lowercase letters/digits/hyphens (no spaces/underscores)
    # AND free on the shared `cfapps.<region>.hana.ondemand.com` domain (it is
    # first-come-first-served across ALL subaccounts in that region). If
    # `lisa-<space>` ever collides, pin a customer/landscape-specific name like
    # `host: lisa-teag-dev` instead.
    # NOTE: `${space}` expands to the LITERAL space name — if your space is
    # uppercase (e.g. `SANDBOX`), `lisa-${space}` becomes the invalid host
    # `lisa-SANDBOX`. Pin a lowercase literal (`host: lisa-sbx`) in that case.
    properties:
      # ── Destinations (REQUIRED — not defaulted in mta.yaml) ──────────
      # BasicAuth destination for system-level calls / startup fallback.
      SAP_BTP_DESTINATION: "SAP_SYSTEM_TECH_DEV"

      # PrincipalPropagation destination for per-user requests (with JWT).
      SAP_BTP_PP_DESTINATION: "SAP_SYSTEM_SSO_DEV"

      # ── SAP service path (REQUIRED — not defaulted in mta.yaml) ──────
      # ICF path of the zi18n_service handler registered in SICF.
      SAP_I18N_SERVICE_PATH: "/sap/bc/http/sap/zi18n_service"

      # ── Logging ──────────────────────────────────────────────────────
      # LOG_LEVEL: "info"          # debug | info | warn | error
      # LOG_FORMAT: "json"         # text | json

      # ── Authentication (optional) ────────────────────────────────────
      # API keys   key:profile,key2:profile2   profiles: viewer|developer|admin
      # SAP_API_KEYS: "mykey123:developer"

      # OIDC/Entra ID
      # OIDC_ISSUER: "https://login.microsoftonline.com/<tenant>/v2.0"
      # OIDC_AUDIENCE: "api://<app-id>"

      # ── OAuth DCR (optional) ─────────────────────────────────────────
      # TTL (seconds) of dynamic client registrations. Default lets them
      # expire; set 0 so registrations NEVER expire (clients aren't
      # re-prompted to register). Safe to keep in the descriptor.
      # SAP_OAUTH_DCR_TTL_SECONDS: 0
      #
      # The DCR signing secret (the "token" that signs registrations and
      # OAuth state) is a SECRET — do NOT put it here. If unset it falls
      # back to the XSUAA `clientsecret`, which `cf deploy` rotates, so
      # every deploy invalidates cached registrations. Pin a stable value
      # OUT-OF-BAND with `cf set-env` (it survives deploys; verify at
      # startup via the log line `dcrSigningSource: "env"`):
      #
      #   cf set-env lisa-mcp LISA_DCR_SIGNING_SECRET "$(openssl rand -base64 48)"
      #   cf restart lisa-mcp

# ── XSUAA xsappname — REQUIRED when running >1 instance per subaccount ─
# `xs-security.json` pins `xsappname: lisa`, which XSUAA turns into the appid
# `lisa!t<tenant>`. That appid is UNIQUE PER SUBACCOUNT (tenant): two service
# instances in the same subaccount cannot share it. So the moment you deploy a
# SECOND landscape alongside an existing one in the same subaccount — e.g. a
# `sandbox` instance next to `dev` — you MUST give it its own xsappname here, or
# the deploy fails at service creation with:
#
#   Error creating service "lisa-xsuaa" ... Application with xsappname
#   lisa!t<tenant> already exists.
#
# Uncomment and append this resource block, picking a distinct name per instance
# (e.g. `lisa-sbx`, `lisa-${space}`). It overrides the `xsappname` from
# xs-security.json; scopes/role-templates still resolve against the new appid.
# resources:
#   - name: lisa-xsuaa
#     parameters:
#       config:
#         xsappname: lisa-sbx
