# ──────────────────────────────────────────────────────────────────────
# MTA Extension Descriptor — SCENARIO: SAP BTP ABAP Environment (Steampunk)
#
# Use this when LISA talks to the SAP BTP ABAP Environment ("Steampunk" /
# ABAP Cloud). There is NO Cloud Connector — calls go direct over the
# internet. Per-user requests use an OAuth2SAMLBearerAssertion destination:
# the Destination Service exchanges the user's JWT for a per-user OAuth
# Bearer token (via SAML bearer assertion against the ABAP environment's
# token service), which LISA sends as `Authorization: Bearer …`.
#
# This is a tracked template. Copy it to a real, per-landscape file (all
# `mta-overrides*.mtaext` are gitignored, the `.example` suffix stays tracked):
#
#   cp mta-overrides-btp-abap.mtaext.example mta-overrides-dev.mtaext
#   # edit mta-overrides-dev.mtaext
#   npm run btp:build-deploy-dev
#
# Any property left commented uses the `mta.yaml` value unchanged.
#
# ── BTP destinations to create for this scenario ─────────────────────────
#   ABAP_TECH_DEV   (technical / startup fallback, system-level calls)
#     Type=HTTP  ProxyType=Internet  Authentication=BasicAuthentication
#     (a Communication Arrangement comm user) or OAuth2ClientCredentials
#     URL=https://<host>.abap.<region>.hana.ondemand.com
#   ABAP_SSO_DEV    (per-user OAuth2 SAML bearer)
#     Type=HTTP  ProxyType=Internet  Authentication=OAuth2SAMLBearerAssertion
#     URL=https://<host>.abap.<region>.hana.ondemand.com
#     TokenServiceURL=https://<host>.abap.<region>.hana.ondemand.com/sap/bc/sec/oauth2/token
#     audience / ClientKey=<OAuth client ID from the Communication Arrangement>
#     nameIdFormat=urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress
#
# ABAP environment side: create a Communication System + Communication
# Arrangement exposing your service, establish SAML trust to the BTP
# subaccount IdP, and register the OAuth 2.0 client. Each user needs a
# business user whose EMAIL matches the JWT, with the required developer
# authorizations. (The bound `connectivity` service is unused here — no
# Cloud Connector — but harmless.)
# ──────────────────────────────────────────────────────────────────────

_schema-version: "3.1"
ID: lisa-overrides
extends: lisa

modules:
  - name: lisa-mcp
    parameters:
      host: lisa-${space}          # dev space -> lisa-dev (must be lowercase & globally free)
    properties:
      # ── Destinations (REQUIRED) ──────────────────────────────────────
      SAP_BTP_DESTINATION: "ABAP_TECH_DEV"     # technical, ProxyType=Internet
      SAP_BTP_PP_DESTINATION: "ABAP_SSO_DEV"   # OAuth2SAMLBearerAssertion, ProxyType=Internet

      # ── SAP service path (REQUIRED) ──────────────────────────────────
      # The path of the zi18n_service exposed via your Communication Arrangement.
      SAP_I18N_SERVICE_PATH: "/sap/bc/http/sap/zi18n_service"

      # ── Logging (optional) ───────────────────────────────────────────
      # LOG_LEVEL: "info"          # debug | info | warn | error
      # LOG_FORMAT: "json"         # text | json

# A second instance in the SAME subaccount needs its own xsappname — see the
# "XSUAA xsappname" block in mta-overrides.mtaext.example.
