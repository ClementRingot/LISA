{
  "name": "lisa-server",
  "version": "0.8.2",
  "description": "Standalone MCP Server for SAP object translation — deployable on BTP",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && node esbuild.config.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "format": "biome format --write src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arc-mcp/xsuaa-auth": "^0.1.4",
    "@lisa/core": "*",
    "@modelcontextprotocol/sdk": "^1.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "undici": "^8.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^26.0.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
