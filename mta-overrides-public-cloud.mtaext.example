# ──────────────────────────────────────────────────────────────────────
# MTA Extension Descriptor — SCENARIO: S/4HANA Cloud Public Edition
#
# Use this when LISA talks to S/4HANA Cloud Public Edition (developer
# extensibility / ABAP Cloud). There is NO Cloud Connector — calls go direct
# over the internet. PRINCIPAL PROPAGATION via a SAMLAssertion destination is
# the ONLY supported path for developer access (there is no technical-user /
# Basic path for ADT-style calls). The Destination Service mints a per-user
# SAML assertion (NameID = the user's email from the JWT), which LISA sends as
# `Authorization: SAML2.0 …` + `x-sap-security-session: create`. S/4HC maps the
# email to a business user (per-user authorization + audit trail).
#
# This is a tracked template. Copy it to a real, per-landscape file (all
# `mta-overrides*.mtaext` are gitignored, the `.example` suffix stays tracked):
#
#   cp mta-overrides-public-cloud.mtaext.example mta-overrides-dev.mtaext
#   # edit mta-overrides-dev.mtaext
#   npm run btp:build-deploy-dev
#
# Any property left commented uses the `mta.yaml` value unchanged.
#
# ── REUSE YOUR BAS DESTINATION ────────────────────────────────────────────
# The SAMLAssertion destination is the SAME one SAP Business Application Studio
# uses (typically named `<SYSTEM_ID>_SAML_ASSERTION`). If you already connect
# BAS to this system, just point SAP_BTP_PP_DESTINATION at that destination —
# no new destination needed. (SAP tutorial: "Connect SAP Business Application
# Studio and SAP S/4HANA Cloud System".)
#
# ── BTP destination to create for this scenario ───────────────────────────
#   S4HC_SAML_DEV   (per-user SAMLAssertion — the ONLY destination that matters)
#     Type=HTTP
#     ProxyType=Internet
#     Authentication=SAMLAssertion
#     URL=https://my<NNNNN>-api.s4hana.cloud.sap
#     Audience=<S/4HC OAuth 2.0 SAML2 audience / SAML2 local provider name>
#     AuthnContextClassRef=urn:oasis:names:tc:SAML:2.0:ac:classes:PreviousSession
#     NameIdFormat=urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress
#     Client Key = (leave empty / "set empty")
#     + enable "Use default JDK truststore" so the public S/4HC TLS cert is trusted
#   Harmless BAS hint properties to KEEP if you reuse the BAS destination:
#     HTML5.DynamicDestination=true   HTML5.Timeout=60000
#     WebIDEEnabled=true              WebIDEUsage=odata_abap,dev_abap
#
#   S4HC_TECH_DEV   (technical — OPTIONAL, startup check only)
#     Only there to satisfy the "SAP_BTP_DESTINATION or SAP_URL required" check
#     in packages/server/src/server/config.ts; it is NOT used for developer
#     calls (those all carry a JWT and flow through the SAMLAssertion dest). A
#     minimal OAuth2ClientCredentials destination at the same S/4HC API host is
#     enough. See "Relaxing the technical-destination requirement" in
#     docs_page/btp-deployment.md to drop it entirely.
#     Type=HTTP  ProxyType=Internet  Authentication=OAuth2ClientCredentials
#     URL=https://my<NNNNN>-api.s4hana.cloud.sap
#
# ── SAML trust setup (S/4HC side) ─────────────────────────────────────────
#   1. BTP subaccount -> Connectivity -> Destination Trust -> Generate Trust,
#      then EXPORT the subaccount signing certificate (PEM).
#   2. S/4HC -> Communication Systems -> New: enable "Inbound Only", set
#      "SAML Bearer Assertion Provider" = ON, UPLOAD the BTP certificate, and
#      set the SAML Bearer Issuer to the certificate's Subject CN.
#   No communication arrangement / communication user is needed for the
#   developer connection. Each user needs an S/4HC business user whose EMAIL
#   matches the JWT, holding a developer (extensibility) business role.
#
# (The bound `connectivity` service is OFF by default in mta.yaml — not needed
# here, no Cloud Connector. Internet destinations must connect direct.)
# ──────────────────────────────────────────────────────────────────────

_schema-version: "3.1"
ID: lisa-overrides
extends: lisa

modules:
  - name: lisa-mcp
    parameters:
      host: lisa-${space}          # dev space -> lisa-dev (must be lowercase & globally free)
    properties:
      # ── Destinations ─────────────────────────────────────────────────
      # PP SAMLAssertion destination — the real per-user path (REQUIRED).
      SAP_BTP_PP_DESTINATION: "S4HC_SAML_DEV"  # SAMLAssertion, ProxyType=Internet
      # Technical destination — startup check only, OPTIONAL/vestigial.
      SAP_BTP_DESTINATION: "S4HC_TECH_DEV"     # OAuth2ClientCredentials, ProxyType=Internet

      # ── SAP service path (REQUIRED) ──────────────────────────────────
      # The ICF path of the zi18n_service handler on the S/4HC tenant.
      SAP_I18N_SERVICE_PATH: "/sap/bc/http/sap/zi18n_service"

      # ── Logging (optional) ───────────────────────────────────────────
      # LOG_LEVEL: "info"          # debug | info | warn | error
      # LOG_FORMAT: "json"         # text | json

# A second instance in the SAME subaccount needs its own xsappname — see the
# "XSUAA xsappname" block in mta-overrides.mtaext.example.
